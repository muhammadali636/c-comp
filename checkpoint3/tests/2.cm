/*
   Test 2.cm - Medium: functions, recursion, if-else, while loops
   Authors: Group 25 - Muhammad Ali, Muhammad Tameem Mughal, Richard Milovanov
   Complexity: Medium
   Errors: None - compiles and runs correctly on the TM simulator.
   Expected behavior: Reads a non-negative integer n and outputs the nth
                      Fibonacci number using a recursive helper function
                      and a while-loop driver.
*/

int fib(int n)
{
  if (n <= 1)
    return n;
  else
    return fib(n - 1) + fib(n - 2);
}

void main(void)
{
  int n;
  int i;

  n = input();
  i = 0;
  while (i <= n)
  {
    output(fib(i));
    i = i + 1;
  }
}
