/*
   Test 1.cm - Simple: arithmetic, assignments, input/output in main
   Authors: Group 25 - Muhammad Ali, Muhammad Tameem Mughal, Richard Milovanov
   Complexity: Easy
   Errors: None - compiles and runs correctly on the TM simulator.
   Expected behavior: Reads two integers, outputs their sum, difference,
                      product, and quotient.
*/

void main(void)
{
  int a;
  int b;
  int result;

  a = input();
  b = input();

  result = a + b;
  output(result);

  result = a - b;
  output(result);

  result = a * b;
  output(result);

  result = a / b;
  output(result);
}
