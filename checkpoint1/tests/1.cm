int nums[10];

int minPos(int a[], int lo, int hi) 
{
  int i;
  int best;
  int idx;

  idx = lo;
  best = a[lo];
  i = lo + 1;

  while (i < hi) 
   {
    if (a[i] < best) {
      best = a[i];
      idx = i;
     }
    i = i + 1;
  }
  return idx;
}

void main(void) {
  int t;

  t = 0;
  while (t < 10) {
    nums[t] = input();
    t = t + 1;
   }

  sort(nums, 0, 10);

  t = 0;
  while (t < 10) 
   {
    output(nums[t]);
    t = t + 1;
  }
}