/*
   Type-check 5: check test conditions for if/while are int or bool.
   Expected errors: if condition must be bool or int (foo() is void),
                    function 'output' expects 1 argument(s) but got 2.
*/

void foo(void) { }

void main(void) {
  int x;
  if( x ) output(foo());
  if(foo()) output(x, foo());
}
